{%- style -%}
  .footer-{{ section.id }} {
    --padding-top: {{ section.settings.padding_top }};
    --padding-bottom: {{ section.settings.padding_bottom }};
  }
{%- endstyle -%}

<footer class="site-footer footer-{{ section.id }} section-padding color-{{ section.settings.color_scheme }}"
  style="background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; border-top: {{ section.settings.border_top_width }}px solid {{ section.settings.border_color }};"
>
  <div class="page-width">
    <div class="footer__grid grid--12" style="display: grid; grid-template-columns: repeat(12, 1fr); gap: {{ section.settings.column_gap }}px;">
      {%- for block in section.blocks -%}
        <div class="footer__col" style="grid-column: span {{ block.settings.width_desktop }};" {{ block.shopify_attributes }}>
          {%- case block.type -%}

            {%- when 'link_list' -%}
              {%- if block.settings.heading != blank -%}
                <h4 class="footer__col-title" style="font-size: {{ section.settings.heading_size | divided_by: 10.0 }}rem; font-weight: {{ section.settings.heading_weight }}; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 1.6rem;">
                  {{ block.settings.heading }}
                </h4>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer__links" style="list-style: none;">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li style="margin-bottom: 0.8rem;">
                      <a href="{{ link.url }}" style="font-size: {{ section.settings.link_size | divided_by: 10.0 }}rem; color: {{ section.settings.link_color }}; opacity: 0.7; transition: opacity 150ms;">
                        {{ link.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            {%- when 'text' -%}
              {%- if block.settings.heading != blank -%}
                <h4 class="footer__col-title" style="font-size: {{ section.settings.heading_size | divided_by: 10.0 }}rem; font-weight: {{ section.settings.heading_weight }}; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 1.6rem;">
                  {{ block.settings.heading }}
                </h4>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="footer__text rte" style="font-size: {{ section.settings.link_size | divided_by: 10.0 }}rem; opacity: 0.7; line-height: 1.7;">
                  {{ block.settings.text }}
                </div>
              {%- endif -%}

            {%- when 'brand_info' -%}
              <div class="footer__brand">
                {%- if settings.logo != blank -%}
                  <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name | escape }}" style="max-width: {{ block.settings.logo_width }}px; margin-bottom: 1.6rem;" loading="lazy">
                {%- else -%}
                  <span class="h4" style="display: block; margin-bottom: 1.6rem;">{{ shop.name }}</span>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p style="font-size: 1.3rem; opacity: 0.6; line-height: 1.7; margin-bottom: 1.6rem;">{{ block.settings.description }}</p>
                {%- endif -%}
                {%- if block.settings.show_social -%}
                  {% render 'social-icons', icon_size: 'sm' %}
                {%- endif -%}
              </div>

            {%- when 'newsletter' -%}
              {%- if block.settings.heading != blank -%}
                <h4 class="footer__col-title" style="font-size: {{ section.settings.heading_size | divided_by: 10.0 }}rem; font-weight: {{ section.settings.heading_weight }}; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 1.6rem;">
                  {{ block.settings.heading }}
                </h4>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p style="font-size: 1.3rem; opacity: 0.6; margin-bottom: 1.2rem;">{{ block.settings.description }}</p>
              {%- endif -%}
              {% form 'customer', class: 'footer__newsletter' %}
                <div style="display: flex; gap: 0.8rem;">
                  <input type="email" name="contact[email]" placeholder="{{ 'newsletter.label' | t }}" class="input" required style="flex: 1;" autocomplete="email">
                  <button type="submit" class="btn btn--primary">{{ block.settings.button_text | default: 'newsletter.button_label' | t }}</button>
                </div>
              {% endform %}

            {%- when 'image' -%}
              {%- if block.settings.image != blank -%}
                <div style="text-align: {{ block.settings.alignment }};">
                  {%- if block.settings.url != blank -%}
                    <a href="{{ block.settings.url }}">
                  {%- endif -%}
                  <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.image.alt | escape }}" style="max-width: {{ block.settings.image_width }}px;" loading="lazy">
                  {%- if block.settings.url != blank -%}
                    </a>
                  {%- endif -%}
                </div>
              {%- endif -%}

            {%- when 'social' -%}
              {%- if block.settings.heading != blank -%}
                <h4 class="footer__col-title" style="font-size: {{ section.settings.heading_size | divided_by: 10.0 }}rem; font-weight: {{ section.settings.heading_weight }}; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 1.6rem;">
                  {{ block.settings.heading }}
                </h4>
              {%- endif -%}
              {% render 'social-icons', icon_size: block.settings.icon_size %}

          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    <!-- Footer bottom bar -->
    <div class="footer__bottom flex justify-between items-center border-t" style="margin-top: {{ section.settings.bottom_spacing }}px; padding-top: 2.4rem; font-size: 1.2rem; opacity: 0.5;">
      <span>{{ section.settings.copyright }}</span>
      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment">
          {{ 'sections.footer.payment' | t }}
        </div>
      {%- endif -%}
      {%- if section.settings.powered_by != blank -%}
        <span>{{ section.settings.powered_by }}</span>
      {%- endif -%}
    </div>
  </div>
</footer>

